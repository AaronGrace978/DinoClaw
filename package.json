{
  "name": "dinoclaw",
  "private": true,
  "version": "0.5.5",
  "description": "AI for the people. Desktop AI agent by BostonAi.io",
  "author": "BostonAi.io <hello@bostonai.io>",
  "homepage": "https://bostonai.io",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -p tsconfig.app.json && vite build --config vite.config.pages.ts && cross-env VITE_LINK_PAGES=true vite build --config vite.config.link.ts",
    "build:link": "tsc -p tsconfig.app.json && vite build --config vite.config.link.ts",
    "dev:link": "vite --config vite.config.link.ts",
    "serve:link": "npm run build:link && vite preview --config vite.config.link.ts --host 0.0.0.0 --port 8808",
    "dist": "npm run build && electron-builder",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:nsis": "npm run build && electron-builder --win nsis",
    "dist:linux": "npm run icons && npm run build && electron-builder --linux",
    "dist:appimage": "npm run dist:linux",
    "icons": "node scripts/generate-icons.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "cli": "npx tsx electron/cli.ts"
  },
  "bin": {
    "dinoclaw": "./dist-electron/cli.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "io.bostonai.dinoclaw",
    "productName": "DinoClaw",
    "copyright": "Copyright 2026 BostonAi.io",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@huggingface/transformers/**/*",
      "node_modules/onnxruntime-node/**/*"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icons",
      "category": "Utility",
      "synopsis": "Desktop AI agent — local-first, free, open source",
      "description": "DinoClaw is a free desktop AI agent that runs on your machine. Missions, memory, skills, Telegram/Discord, and more.",
      "desktop": {
        "entry": {
          "StartupWMClass": "DinoClaw",
          "Keywords": "AI;Agent;Assistant;Chat;LLM;Ollama;"
        }
      }
    },
    "appImage": {
      "artifactName": "DinoClaw-${version}-linux-${arch}.${ext}"
    }
  }
}
